<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LeetCode Flashcard Deck</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap');
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0d0f14; --card-front: #13161e; --card-back: #0e1620;
    --accent: #3dd6f5; --accent2: #f5a623; --green: #4ade80;
    --red: #f87171; --text: #e8eaf0; --muted: #6b7280; --border: #1e2535;
  }
  body {
    background: var(--bg); font-family: 'Syne', sans-serif; color: var(--text);
    min-height: 100vh; display: flex; flex-direction: column;
    align-items: center; justify-content: center; padding: 24px; gap: 20px;
  }
  /* Header */
  .header { text-align: center; display: flex; flex-direction: column; gap: 6px; }
  .header h1 { font-size: 22px; font-weight: 800; }
  .header p  { font-size: 13px; color: var(--muted); }
  /* Progress bar */
  .progress-wrap { width: 100%; max-width: 680px; display: flex; flex-direction: column; gap: 6px; }
  .progress-info { display: flex; justify-content: space-between; font-size: 12px; color: var(--muted); }
  .progress-bar  { height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--accent); border-radius: 99px; transition: width 0.4s ease; }
  /* Card scene */
  .scene { width: 100%; max-width: 680px; height: 480px; perspective: 1200px; cursor: pointer; }
  .card  { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform 0.65s cubic-bezier(0.4,0,0.2,1); }
  .card.flipped { transform: rotateY(180deg); }
  .face {
    position: absolute; inset: 0; border-radius: 20px; border: 1px solid var(--border);
    backface-visibility: hidden; -webkit-backface-visibility: hidden;
    padding: 32px; display: flex; flex-direction: column; gap: 16px; overflow: hidden;
  }
  .face::before { content: ''; position: absolute; inset: 0; border-radius: 20px; pointer-events: none; }
  .front { background: var(--card-front); }
  .front::before { background: radial-gradient(ellipse at 80% 20%, rgba(61,214,245,0.07) 0%, transparent 60%); }
  .back  { background: var(--card-back); transform: rotateY(180deg); }
  .back::before  { background: radial-gradient(ellipse at 20% 80%, rgba(74,222,128,0.07) 0%, transparent 60%); }
  /* Tags */
  .tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; padding: 4px 12px; border-radius: 99px; width: fit-content;
  }
  .tag-easy     { background: rgba(74,222,128,0.12); color: var(--green);   border: 1px solid rgba(74,222,128,0.3); }
  .tag-medium   { background: rgba(245,166,35,0.15); color: var(--accent2); border: 1px solid rgba(245,166,35,0.3); }
  .tag-hard     { background: rgba(248,113,113,0.12);color: var(--red);     border: 1px solid rgba(248,113,113,0.3); }
  .tag-on       { background: rgba(61,214,245,0.1);  color: var(--accent);  border: 1px solid rgba(61,214,245,0.25); }
  .tag-answer   { background: rgba(74,222,128,0.1);  color: var(--green);   border: 1px solid rgba(74,222,128,0.25); }
  .tag-extra    { background: rgba(245,166,35,0.1);  color: var(--accent2); border: 1px solid rgba(245,166,35,0.25); }
  /* Text */
  .question-title { font-size: 21px; font-weight: 800; line-height: 1.3; }
  .question-body  { font-size: 13.5px; color: #9ca3af; line-height: 1.75; }
  code {
    color: var(--accent); background: rgba(61,214,245,0.08);
    padding: 2px 6px; border-radius: 4px;
    font-family: 'JetBrains Mono', monospace; font-size: 0.88em;
  }
  /* Hint box */
  .hint-box { background: rgba(255,255,255,0.03); border: 1px solid var(--border); border-radius: 12px; padding: 14px 18px; }
  .hint-box p  { font-size: 11px; color: #6b7280; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; }
  .hint-box ul { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .hint-box li { font-size: 13px; color: #9ca3af; display: flex; align-items: flex-start; gap: 8px; line-height: 1.5; }
  .hint-box li::before { content: '→'; color: var(--accent); flex-shrink: 0; font-weight: 700; }
  .flip-hint { margin-top: auto; font-size: 12px; color: var(--muted); text-align: center; }
  /* Back */
  .section-label { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 7px; }
  .steps { list-style: none; display: flex; flex-direction: column; gap: 7px; }
  .steps li { display: flex; align-items: flex-start; gap: 12px; font-size: 13px; line-height: 1.6; color: #c9d1de; }
  .step-num {
    background: rgba(61,214,245,0.12); color: var(--accent);
    font-size: 11px; font-weight: 800; min-width: 22px; height: 22px;
    border-radius: 6px; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }
  .step-key { color: var(--accent2); font-weight: 700; }
  .code-block {
    background: rgba(0,0,0,0.35); border: 1px solid var(--border); border-radius: 10px;
    padding: 12px 16px; font-family: 'JetBrains Mono', monospace; font-size: 11.5px;
    line-height: 1.7; overflow-x: auto; white-space: pre; color: #c9d1de;
  }
  .kw { color: #c792ea; } .fn { color: var(--accent); }
  .cm { color: #546e7a; font-style: italic; } .num { color: var(--accent2); }
  .complexity-row { display: flex; gap: 10px; flex-wrap: wrap; }
  .badge { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 8px; }
  .badge-time  { background: rgba(61,214,245,0.1);  color: var(--accent);  border: 1px solid rgba(61,214,245,0.2); }
  .badge-space { background: rgba(245,166,35,0.1);  color: var(--accent2); border: 1px solid rgba(245,166,35,0.2); }
  /* Controls */
  .controls { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; justify-content: center; }
  button {
    font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700;
    letter-spacing: 0.05em; border: none; border-radius: 10px;
    padding: 10px 22px; cursor: pointer; transition: all 0.2s ease;
  }
  .btn-nav   { background: rgba(255,255,255,0.05); color: var(--muted);  border: 1px solid var(--border); }
  .btn-nav:hover   { background: rgba(255,255,255,0.1); color: var(--text); }
  .btn-nav:disabled { opacity: 0.25; cursor: default; transform: none; }
  .btn-flip  { background: rgba(61,214,245,0.1);  color: var(--accent); border: 1px solid rgba(61,214,245,0.3); }
  .btn-flip:hover  { background: rgba(61,214,245,0.2); transform: translateY(-1px); }
  .btn-again { background: rgba(248,113,113,0.1); color: var(--red);    border: 1px solid rgba(248,113,113,0.25); }
  .btn-again:hover { background: rgba(248,113,113,0.2); }
  .btn-good  { background: rgba(74,222,128,0.1);  color: var(--green);  border: 1px solid rgba(74,222,128,0.25); }
  .btn-good:hover  { background: rgba(74,222,128,0.2); }
  .review-btns { display: none; gap: 12px; }
  .status { font-size: 12px; color: var(--muted); text-align: center; min-height: 18px; }
  /* Deck nav dots */
  .dots { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; max-width: 680px; }
  .dot {
    width: 10px; height: 10px; border-radius: 99px; cursor: pointer;
    background: var(--border); border: 1px solid transparent;
    transition: all 0.2s;
  }
  .dot.active  { background: var(--accent); width: 24px; }
  .dot.correct { background: var(--green); }
  .dot.wrong   { background: var(--red); }
</style>
</head>
<body>

<div class="header">
  <h1>📇 LeetCode Deck</h1>
  <p id="deck-subtitle">2 cards · Keep adding as you solve more!</p>
</div>

<div class="progress-wrap">
  <div class="progress-info">
    <span id="prog-label">Card <span id="prog-cur">1</span> of <span id="prog-total">2</span></span>
    <span id="prog-score">0 correct</span>
  </div>
  <div class="progress-bar"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
</div>

<div class="scene" onclick="flipCard()">
  <div class="card" id="card">
    <div class="face front" id="front-face"></div>
    <div class="face back"  id="back-face"></div>
  </div>
</div>

<div class="controls">
  <button class="btn-nav" id="btn-prev" onclick="navigate(-1)">← Prev</button>
  <button class="btn-flip" onclick="flipCard()">↩ Flip</button>
  <div class="review-btns" id="reviewBtns">
    <button class="btn-again" onclick="markResult('again')">✗ Again</button>
    <button class="btn-good"  onclick="markResult('good')">✓ Got it</button>
  </div>
  <button class="btn-nav" id="btn-next" onclick="navigate(1)">Next →</button>
</div>

<div class="dots" id="dots"></div>
<div class="status" id="status">Click the card to reveal the answer</div>

<script>
// =============================================================
//  CARD DATA — ADD NEW CARDS AT THE BOTTOM OF THIS ARRAY
//  Each card has: id, number, title, difficulty, tags[],
//    hints[], steps[], code (HTML string), time, space
// =============================================================
const CARDS = [
  {
    id: 1,
    number: "#1",
    title: "Two Sum",
    difficulty: "easy",
    tags: ["HashMap pattern"],
    hints: [
      "What's the complement of <code>nums[i]</code> that you need to find?",
      "What do you store in the map — value or index?",
      "Do you check the map <strong>before</strong> or after inserting?"
    ],
    problem: `Given an array <code>nums</code> and an integer <code>target</code>, return the <strong style="color:var(--text)">indices</strong> of the two numbers that add up to <code>target</code>.<br><br>Each input has <strong style="color:var(--text)">exactly one solution</strong>. You may not use the same element twice.`,
    steps: [
      ["Create", "<span class='step-key'>HashMap&lt;Integer, Integer&gt;</span> mapping <em>value → index</em>"],
      ["For each nums[i]", "compute <span class='step-key'>diff = target − nums[i]</span>"],
      ["Check map first —", "if <code>diff</code> exists, return <code>{map.get(diff), i}</code>"],
      ["Otherwise,", "<span class='step-key'>put nums[i] → i</span> into the map and continue"]
    ],
    code: `<span class="kw">Map</span>&lt;<span class="kw">Integer</span>,<span class="kw">Integer</span>&gt; map = <span class="kw">new</span> <span class="fn">HashMap</span>&lt;&gt;();
<span class="kw">for</span> (<span class="kw">int</span> i = <span class="num">0</span>; i &lt; nums.length; i++) {
  <span class="kw">int</span> diff = target - nums[i];
  <span class="kw">if</span> (map.<span class="fn">containsKey</span>(diff))
    <span class="kw">return new int</span>[]{ map.<span class="fn">get</span>(diff), i };
  map.<span class="fn">put</span>(nums[i], i); <span class="cm">// store AFTER checking</span>
}
<span class="kw">return null</span>;`,
    time: "O(n)", space: "O(n)"
  },

  {
    id: 2,
    number: "#128",
    title: "Longest Consecutive Sequence",
    difficulty: "medium",
    tags: ["HashSet pattern", "O(n) required"],
    hints: [
      "What data structure gives O(1) lookup?",
      "How do you avoid counting sequences multiple times?",
      "When should you <strong>start</strong> counting a new streak?"
    ],
    problem: `Given an <strong style="color:var(--text)">unsorted array</strong> of integers <code>nums</code>, return the length of the <strong style="color:var(--text)">longest consecutive elements sequence</strong>. Must run in <code>O(n)</code> time.`,
    steps: [
      ["Put all numbers", "into a <span class='step-key'>HashSet</span> (deduplicates + O(1) lookup)"],
      ["Loop each number —", "<span class='step-key'>skip if num−1 exists</span> (not a sequence start)"],
      ["When it IS a start:", "walk forward with <span class='step-key'>while (set.contains(cur+1))</span>"],
      ["Track", "<code style='font-size:11px'>longestStreak = max(longest, current)</code> after while exits"]
    ],
    code: `<span class="kw">Set</span>&lt;<span class="kw">Integer</span>&gt; set = <span class="kw">new</span> <span class="fn">HashSet</span>&lt;&gt;();
<span class="kw">for</span> (<span class="kw">int</span> n : nums) set.<span class="fn">add</span>(n);

<span class="kw">int</span> longest = <span class="num">0</span>;
<span class="kw">for</span> (<span class="kw">int</span> n : set) {
  <span class="kw">if</span> (!set.<span class="fn">contains</span>(n - <span class="num">1</span>)) { <span class="cm">// sequence start only</span>
    <span class="kw">int</span> cur = n, streak = <span class="num">1</span>;
    <span class="kw">while</span> (set.<span class="fn">contains</span>(cur + <span class="num">1</span>)) { cur++; streak++; }
    longest = <span class="fn">Math.max</span>(longest, streak);
  }
}
<span class="kw">return</span> longest;`,
    time: "O(n)", space: "O(n)"
  },

  // ─────────────────────────────────────────────
  //  ADD YOUR NEXT CARD HERE — copy the block
  //  above, change the fields, and you're done!
  // ─────────────────────────────────────────────
];
// =============================================================

// ── State ────────────────────────────────────────────────────
let current = 0;
let flipped  = false;
let results  = {}; // cardId → 'good' | 'again'

// ── Build card HTML ──────────────────────────────────────────
function diffTag(d) {
  if (d === 'easy')   return `<span class="tag tag-easy">★ Easy</span>`;
  if (d === 'medium') return `<span class="tag tag-medium">⚡ Medium</span>`;
  return `<span class="tag tag-hard">🔥 Hard</span>`;
}

function renderCard(idx) {
  const c = CARDS[idx];

  // Front
  const tagsHTML = c.tags.map(t => `<span class="tag tag-on">${t}</span>`).join('');
  const hintsHTML = c.hints.map(h => `<li>${h}</li>`).join('');
  document.getElementById('front-face').innerHTML = `
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      ${diffTag(c.difficulty)} ${tagsHTML}
    </div>
    <div class="question-title">${c.number} · ${c.title}</div>
    <div class="question-body">${c.problem}</div>
    <div class="hint-box">
      <p>Key questions to ask yourself</p>
      <ul>${hintsHTML}</ul>
    </div>
    <div class="flip-hint">👆 Click card to reveal solution</div>
  `;

  // Back
  const stepsHTML = c.steps.map(([label, rest], i) =>
    `<li><span class="step-num">${i+1}</span><span><span class="step-key">${label}</span> ${rest}</span></li>`
  ).join('');
  document.getElementById('back-face').innerHTML = `
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <span class="tag tag-answer">✓ Solution</span>
    </div>
    <div>
      <div class="section-label">Algorithm steps</div>
      <ul class="steps">${stepsHTML}</ul>
    </div>
    <div>
      <div class="section-label">Java skeleton</div>
      <div class="code-block">${c.code}</div>
    </div>
    <div>
      <div class="section-label">Complexity</div>
      <div class="complexity-row">
        <span class="badge badge-time">Time: ${c.time}</span>
        <span class="badge badge-space">Space: ${c.space}</span>
      </div>
    </div>
  `;

  // Progress
  document.getElementById('prog-cur').textContent   = idx + 1;
  document.getElementById('prog-total').textContent = CARDS.length;
  const correct = Object.values(results).filter(v => v === 'good').length;
  document.getElementById('prog-score').textContent = `${correct} correct`;
  document.getElementById('prog-fill').style.width  = `${((idx+1)/CARDS.length)*100}%`;
  document.getElementById('deck-subtitle').textContent =
    `${CARDS.length} card${CARDS.length !== 1 ? 's' : ''} · Keep adding as you solve more!`;

  // Nav buttons
  document.getElementById('btn-prev').disabled = idx === 0;
  document.getElementById('btn-next').disabled = idx === CARDS.length - 1;

  // Dots
  const dots = document.getElementById('dots');
  dots.innerHTML = CARDS.map((card, i) => {
    let cls = 'dot';
    if (i === idx) cls += ' active';
    else if (results[card.id] === 'good')  cls += ' correct';
    else if (results[card.id] === 'again') cls += ' wrong';
    return `<div class="${cls}" onclick="goTo(${i})"></div>`;
  }).join('');
}

// ── Interactions ─────────────────────────────────────────────
function flipCard() {
  flipped = !flipped;
  document.getElementById('card').classList.toggle('flipped', flipped);
  document.getElementById('reviewBtns').style.display = flipped ? 'flex' : 'none';
  document.getElementById('status').textContent = flipped
    ? 'How well did you remember it?'
    : 'Click the card to reveal the answer';
}

function markResult(result) {
  results[CARDS[current].id] = result;
  flipped = false;
  document.getElementById('card').classList.remove('flipped');
  document.getElementById('reviewBtns').style.display = 'none';
  const correct = Object.values(results).filter(v => v === 'good').length;
  document.getElementById('status').textContent = result === 'good'
    ? `✓ Nice! ${correct} of ${CARDS.length} correct.`
    : `Marked for review. Keep practicing!`;
  renderCard(current);
  // Auto-advance after a moment
  if (current < CARDS.length - 1) setTimeout(() => navigate(1), 900);
}

function navigate(dir) {
  current = Math.max(0, Math.min(CARDS.length - 1, current + dir));
  flipped = false;
  document.getElementById('card').classList.remove('flipped');
  document.getElementById('reviewBtns').style.display = 'none';
  document.getElementById('status').textContent = 'Click the card to reveal the answer';
  renderCard(current);
}

function goTo(idx) {
  current = idx;
  flipped = false;
  document.getElementById('card').classList.remove('flipped');
  document.getElementById('reviewBtns').style.display = 'none';
  document.getElementById('status').textContent = 'Click the card to reveal the answer';
  renderCard(current);
}

// ── Init ─────────────────────────────────────────────────────
renderCard(0);
</script>
</body>
</html>